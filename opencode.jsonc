{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "atlassian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/mcp"
      ],
      "enabled": true
    },

    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },

    "context-mode": {
      "type": "local",
      "command": ["context-mode"],
      "enabled": true
    }
  },

  "plugin": ["context-mode"]
}
